{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "name": "elixant-technology/utility",
  "description": "Simple and easy-to-use Event Dispatcher.",
  "keywords": ["elixant", "event", "dispatcher", "platform"],
  "type": "library",
  "license": "MIT",
  "authors": [
	{
	  "name": "Alexander M. Schmautz",
	  "email": "president@elixant-technology.com",
	  "homepage": "https://elixant-technology.com"
	}
  ],
  "require": {
	"php": "^7.4|^8.0",
	"ext-json": "*",
	"ext-mbstring": "*",
	"elixant-technology/container": "*",
	"nesbot/carbon": "^2.1",
	"voku/portable-ascii": "^1.4.8",
	"symfony/var-dumper": "^5.1.4",
	"doctrine/inflector": "^1.4"
  },
  "require-dev": {
	"ramsey/uuid": "^4.0",
	"league/commonmark": "^1.3",
	"vlucas/phpdotenv": "^5.2"
  },
  "suggest": {
	"league/commonmark": "Required to use Str::markdown() and Stringable::markdown() (^1.3).",
	"ramsey/uuid": "Required to use Str::uuid() (^4.0).",
	"vlucas/phpdotenv": "Required to use the Env class and env helper (^5.2)."
  },
  "autoload": {
	"psr-4": {
	  "Elixant\\Components\\Utility\\": "src"
	},
	"files": [
	  "src/helpers.php"
	]
  },
  "config": {
	"optimize-autoloader": true
  }
}